# ==========================================
# Professional Full-Stack Project .gitignore
# ==========================================

# ------------------------------------------
# Logs
# ------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# ------------------------------------------
# Runtime Data & Diagnostic Reports
# ------------------------------------------
pids/
*.pid
*.seed
*.pid.lock
lib-cov/

# ------------------------------------------
# Dependencies
# ------------------------------------------
node_modules/
jspm_packages/
web_modules/
bower_components/

# ------------------------------------------
# Build & Compilation Output
# ------------------------------------------
dist/
dist-ssr/
build/
build/Release/
out/
.next/
.nuxt/
.vuepress/dist/
**/.vitepress/dist
.svelte-kit/
.serverless/
.fusebox/
*.tsbuildinfo

# ------------------------------------------
# Testing & Coverage
# ------------------------------------------
coverage/
*.lcov
.nyc_output/

# ------------------------------------------
# Caches & Intermediate Files
# ------------------------------------------
.npm/
.eslintcache
.stylelintcache
.node_repl_history
*.tgz
.yarn-integrity
.cache/
.parcel-cache/
.temp/
**/.vitepress/cache/
.docusaurus/
.firebase/
.grunt/
.lock-wscript

# ------------------------------------------
# Environment Variables
# ------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# Let .env.example or .env.template be committed
!.env.example
!.env.template

# ------------------------------------------
# OS Generated Files
# ------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
ehthumbs_vista.db
[Tt]humbs.db
Desktop.ini

# ------------------------------------------
# IDE / Editor Folders
# ------------------------------------------
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.sublime-workspace
*.sublime-project
.tern-port
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.vscode-test/

# ------------------------------------------
# Package Manager Specific
# ------------------------------------------
# Yarn v2+
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# Vite
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# ------------------------------------------
# Application Specific (DB, local data)
# ------------------------------------------
.dynamodb/
*.sqlite
*.sqlite3
db.json

# ------------------------------------------
# Optional / Custom Exceptions
# ------------------------------------------
# Add any project-specific exact paths here:
